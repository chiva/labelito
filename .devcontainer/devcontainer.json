{
  "name": "labelito",
  // Compose-based so the same container works under plain `docker/podman compose`
  // (including SELinux/rootless-podman hosts like Fedora/Bazzite — see the
  // security_opt + comments in docker-compose.yml), not only the VS Code flow.
  "dockerComposeFile": "docker-compose.yml",
  "service": "dev",
  "workspaceFolder": "/workspace",
  "forwardPorts": [8765],
  "portsAttributes": {
    "8765": { "label": "labelito web UI", "onAutoForward": "notify" }
  },
  // git identity from gh, uv sync, pre-commit hooks, Playwright chromium, icons.
  "postCreateCommand": "bash .devcontainer/postCreate.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "charliermarsh.ruff",
        "astral-sh.ty",
        "ms-python.python",
        "tamasfe.even-better-toml",
        "redhat.vscode-yaml",
        "eamodio.gitlens",
        "github.vscode-github-actions"
      ],
      "settings": {
        "python.defaultInterpreterPath": "${containerWorkspaceFolder}/.venv/bin/python"
      }
    }
  }
}

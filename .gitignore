# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
dist/
build/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Tooling caches
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Coverage
.coverage
.coverage.*
htmlcov/
coverage.xml

# Environment / secrets
.env
.env.*

# Vendored icon collections — fetched into the image at build time (scripts/fetch-icons.sh for dev)
/assets/icon-collections/

# DejaVu fonts — fetched for local dev (scripts/fetch-fonts.sh); the image installs them via apt
/fonts/

# Node deps for the icon collections — installed from the committed pnpm-lock.yaml; never committed
/node_modules/

# Local data directory — runtime/generated files not for version control
/data/
docker-compose.override.yml

# Dev container Feature lock — auto-generated by `devcontainer up`. Not committed: Renovate's
# devcontainer manager isn't enabled here and wouldn't maintain the lock anyway, so a committed
# digest would silently freeze the uv Feature. Letting it resolve fresh each build keeps it current.
.devcontainer/devcontainer-lock.json

# Local merge artifacts: numbered per-commit zips staged for the manual merge workflow, never repo content
commit-zips/

# OS / editor
.DS_Store

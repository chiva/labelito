# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
dist/
build/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Tooling caches
.mypy_cache/
.ruff_cache/
.pytest_cache/
.playwright-mcp

# Coverage
.coverage
.coverage.*
htmlcov/
coverage.xml

# Environment / secrets
.env
.env.*

# Vendored icon collections — fetched into the image at build time (scripts/fetch-icons.sh for dev)
/assets/icon-collections/

# DejaVu fonts — fetched for local dev (scripts/fetch-fonts.sh); the image installs them via apt
/fonts/

# Node deps for the icon collections — installed from the committed pnpm-lock.yaml; never committed
/node_modules/

# pnpm's in-project store fallback — created when the store dir lives on another filesystem
# (e.g. the dev container's bind-mounted workspace, where hardlinks can't cross devices)
.pnpm-store/

# Label gallery previews — rendered at deploy time by scripts/build_gallery.py (never committed;
# the Pages workflow regenerates them so they can't drift from templates/).
/site/assets/samples/

# Local data directory — runtime/generated files not for version control.
# The directory itself IS tracked (via data/.gitkeep) so a fresh clone ships it owned by the
# cloning user; otherwise Docker auto-creates the ./data bind-mount source as root and the
# non-root container crash-loops on the history DB (docs/improvement-plan.md F1).
/data/*
!/data/.gitkeep
docker-compose.override.yml

# Dev container shell history — persisted across rebuilds via a bind mount (docker-compose.yml)
.devcontainer/.history/

# OS / editor
.DS_Store
commit-zips/

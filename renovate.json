{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "enabledManagers": ["pep621", "github-actions", "dockerfile", "npm"],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 4am on monday"]
  },
  "minimumReleaseAge": "2 days",
  "packageRules": [
    {
      "description": "Group all non-major bumps into one PR.",
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "non-major dependencies"
    },
    {
      "description": "Icon collections: kept in their own group (separate from the shared non-major PR) so a fetch-icons.sh CI failure is attributable to a single PR.",
      "matchManagers": ["npm"],
      "matchPackageNames": [
        "@fortawesome/fontawesome-free",
        "@material-symbols/svg-400",
        "@primer/octicons"
      ],
      "groupName": "icon collections"
    }
  ]
}
